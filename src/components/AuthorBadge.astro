---
import type { CollectionEntry } from 'astro:content';

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;
const { name, bio, avatar } = author.data;
---

<a
  href={`/authors/${author.id}`}
  class="group flex items-center gap-4 rounded-lg p-4 transition-colors hover:bg-[var(--color-surface-alt)]"
>
  {avatar ? (
    <img
      src={avatar}
      alt={name}
      class="h-12 w-12 rounded-full object-cover ring-2 ring-[var(--color-surface-border)] group-hover:ring-[var(--color-primary-400)] transition-all"
    />
  ) : (
    <div class="flex h-12 w-12 items-center justify-center rounded-full bg-gradient-to-br from-[var(--color-primary-400)] to-[var(--color-primary-600)] ring-2 ring-[var(--color-surface-border)] group-hover:ring-[var(--color-primary-400)] text-white font-semibold text-sm transition-all">
      {name.charAt(0).toUpperCase()}
    </div>
  )}
  <div class="min-w-0 flex-1">
    <p class="font-medium text-[var(--color-text-primary)]">{name}</p>
    <p class="text-sm text-[var(--color-text-muted)] line-clamp-1">{bio}</p>
  </div>
  <svg class="h-4 w-4 text-[var(--color-text-muted)] opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
  </svg>
</a>
