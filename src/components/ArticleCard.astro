---
import type { CollectionEntry } from 'astro:content';
import TagList from './TagList.astro';

interface Props {
  article: CollectionEntry<'articles'>;
  authorName: string;
  featured?: boolean;
}

const { article, authorName, featured = false } = Astro.props;
const { title, description, date, tags, author } = article.data;

const formattedDate = new Date(date).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article
  class:list={[
    'group rounded-lg px-6 py-5 transition-colors',
    featured
      ? 'bg-[var(--color-surface-alt)] border border-[var(--color-surface-border)]'
      : 'hover:bg-[var(--color-surface-alt)]',
  ]}
>
  <div class="mb-2 flex flex-wrap items-center gap-2 text-xs text-[var(--color-text-muted)]">
    <a
      href={`/authors/${author.id}`}
      class="font-medium hover:text-[var(--color-text-primary)] transition-colors"
    >
      {authorName}
    </a>
    <span>/</span>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
  <a href={`/articles/${article.id}`} class="block">
    <h2
      class:list={[
        'font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-primary-600)] dark:group-hover:text-[var(--color-primary-400)] transition-colors',
        featured ? 'text-2xl tracking-tight' : 'text-lg',
      ]}
    >
      {title}
    </h2>
  </a>
  <p class="mt-2 text-sm text-[var(--color-text-secondary)] leading-relaxed">{description}</p>
  <div class="mt-3">
    <TagList tags={tags} />
  </div>
</article>
