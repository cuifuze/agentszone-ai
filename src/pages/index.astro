---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const allArticles = await getCollection('articles', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const articles = allArticles.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const authors = await getCollection('authors');
const authorMap = new Map(authors.map((a) => [a.id, a.data.name]));
---

<BaseLayout
  title="Agents 特区"
  description="一线实践者的AI agent管理经验，从个人探索到组织级实践。"
>
  <section class="mb-16">
    <h1 class="text-4xl font-extrabold tracking-tight text-[var(--color-text-primary)] sm:text-5xl lg:text-6xl">
      Agents 特区
    </h1>
    <p class="mt-6 text-lg text-[var(--color-text-secondary)] leading-relaxed max-w-2xl">
      AI agent已经不是实验品了。团队在用agent写代码、做测试、跑部署、处理运维。
    </p>
    <p class="mt-3 text-lg text-[var(--color-text-muted)] leading-relaxed max-w-2xl">
      汇集一线实践者的经验。不谈概念，谈落地。
    </p>
    <div class="mt-8 h-px w-16 bg-[var(--color-primary-500)]"></div>
  </section>

  <section>
    <h2 class="mb-8 text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)]">
      最新文章
    </h2>
    <div class="divide-y divide-[var(--color-surface-border)]">
      {articles.map((article, index) => (
        <div class={index === 0 ? 'pb-2' : 'py-2'}>
          <ArticleCard
            article={article}
            authorName={authorMap.get(article.data.author.id) ?? 'Unknown'}
            featured={index === 0}
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
